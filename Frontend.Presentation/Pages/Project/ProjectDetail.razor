@page "/projects/details/{Id:guid}"
@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Project
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers
@inject IProjectService ProjectService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">Dettaglio progetto</h2>
            <div class="page-subtitle">Informazioni complete sul progetto selezionato</div>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error-box">@ErrorMessage</div>
    }
    else if (Project is not null)
    {
        <div class="details-card">
            <div class="details-row">
                <span class="label">Nome</span>
                <span class="value">@Project.Name</span>
            </div>
            <div class="details-row">
                <span class="label">Azienda</span>
                <span class="value">@Project.CompanyName</span>
            </div>
            <div class="details-row">
                <span class="label">Tariffa oraria</span>
                <span class="value"><span class="badge badge-brand">@($"{Project.HourlyRate} €/h")</span></span>
            </div>
            <div class="details-row">
                <span class="label">ID</span>
                <span class="value"><code>@Project.Id</code></span>
            </div>

            <div class="form-actions">
                <button class="btn btn-secondary" @onclick="GoBack">Indietro</button>
                <AuthorizeRoles Roles="@(new[] { Roles.ProjectManager, Roles.Admin })">
                    <button class="btn btn-primary" @onclick="Edit">Modifica</button>
                </AuthorizeRoles>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private ProjectDto? Project;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav,
                Roles.ProjectManager, Roles.Admin))
            return;

        try
        {
            Project = await ProjectService.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/projects");
    private void Edit() => Nav.NavigateTo($"/projects/form/{Id}");
}
