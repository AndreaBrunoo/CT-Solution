@page "/projects"
@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Project
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers
@inject IProjectService ProjectService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">Progetti</h2>
            <div class="page-subtitle">Tutti i progetti attivi e archiviati</div>
        </div>
        <div class="page-actions">
            <AuthorizeRoles Roles="@(new[] { Roles.ProjectManager, Roles.Admin })">
                <button class="btn btn-success" @onclick="Create">Nuovo progetto</button>
            </AuthorizeRoles>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error-box">@ErrorMessage</div>
    }
    else if (Projects is not null)
    {
        @if (Projects.Count == 0)
        {
            <div class="empty-state">Nessun progetto presente. Creane uno per iniziare.</div>
        }
        else
        {
            <div class="data-card">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Azienda</th>
                            <th>Tariffa</th>
                            <th class="col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Projects)
                        {
                            <tr>
                                <td><strong>@p.Name</strong></td>
                                <td>@p.CompanyName</td>
                                <td><span class="badge">@($"{p.HourlyRate} €/h")</span></td>
                                <td class="col-actions">
                                    <button class="btn btn-secondary btn-sm" @onclick="() => Details(p.Id)">Dettagli</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@code {
    private IReadOnlyList<ProjectDto>? Projects;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav,
                Roles.ProjectManager, Roles.Admin))
            return;

        try
        {
            Projects = await ProjectService.GetAllAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void Details(Guid id)
    {
        Nav.NavigateTo($"/projects/details/{id}");
    }

    private void Create()
    {
        Nav.NavigateTo("/projects/form");
    }
}
