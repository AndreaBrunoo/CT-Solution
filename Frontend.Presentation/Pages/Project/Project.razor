@page "/projects"
@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Project
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers
@inject IProjectService ProjectService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="project-container">
    <h2 class="title">Progetti</h2>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error">@ErrorMessage</div>
    }
    else if (Projects is not null)
    {
        <div class="actions-top">
            <AuthorizeRoles Roles="@(new[] { Roles.ProjectManager, Roles.Admin })">
                <button class="btn-create" @onclick="Create">+ Nuovo Progetto</button>
            </AuthorizeRoles>
        </div>

        <div class="table-wrapper">
            <table class="project-table">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Azienda</th>
                        <th>Tariffa</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var p in Projects)
                    {
                        <tr>
                            <td>@p.Name</td>
                            <td>@p.CompanyName</td>
                            <td>@($"{p.HourlyRate} €/h")</td>
                            <td>
                                <button class="btn-details" @onclick="() => Details(p.Id)">
                                    Dettagli
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private IReadOnlyList<ProjectDto>? Projects;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav,
                Roles.ProjectManager, Roles.Admin))
            return;

        try
        {
            Projects = await ProjectService.GetAllAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void Details(Guid id)
    {
        Nav.NavigateTo($"/projects/details/{id}");
    }

    private void Create()
    {
        Nav.NavigateTo("/projects/form");
    }
}
