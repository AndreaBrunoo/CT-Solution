@layout EmptyLayout
@using Frontend.Domain.Dtos.User;
@using Frontend.Domain.Contracts;
@using Frontend.Application.Services;

@page "/"
@inject IUserService UserService
@inject ITokenProvider TokenProvider
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-card">
        <div class="login-brand">
            <div class="login-logo">CT</div>
            <h1 class="login-title">CT Solution</h1>
            <p class="login-subtitle">Accedi al tuo account</p>
        </div>

        <EditForm Model="@model" OnValidSubmit="@DoLogin" class="login-form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" class="form-control" @bind-Value="model.Email" placeholder="nome@azienda.it" autocomplete="email" />
                <ValidationMessage For="@(() => model.Email)" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <InputText id="password" class="form-control" type="password" @bind-Value="model.Password" placeholder="••••••••" autocomplete="current-password" />
                <ValidationMessage For="@(() => model.Password)" />
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert-error">@ErrorMessage</div>
            }

            <button type="submit" class="btn-login" disabled="@IsBusy">
                @if (IsBusy)
                {
                    <span class="spinner"></span>
                    <span>Accesso in corso…</span>
                }
                else
                {
                    <span>Accedi</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            <span>CT Solution</span>
            <span>·</span>
            <span>Gestione WorkLog</span>
        </div>
    </div>
</div>

@code {
    private LoginDto model = new();
    private bool IsBusy = false;
    private string ErrorMessage = string.Empty;

    private async Task DoLogin()
    {
        ErrorMessage = string.Empty;
        IsBusy = true;

        try
        {
            var result = await UserService.LoginAsync(model);

            if (result?.Token is null || string.IsNullOrWhiteSpace(result.Token))
            {
                ErrorMessage = "Credenziali non valide.";
                return;
            }

            await TokenProvider.SetTokenAsync(result.Token);

            // Carico l'utente corrente per il guard di autorizzazione
            var me = await UserService.GetCurrentUserAsync();
            if (me is not null)
                await CurrentUser.SetAsync(me);

            Nav.NavigateTo("/Dashboard");
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }
}
