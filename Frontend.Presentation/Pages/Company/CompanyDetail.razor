@page "/companies/details/{Id:guid}"
@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Company
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers
@inject ICompanyService CompanyService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">Dettaglio azienda</h2>
            <div class="page-subtitle">Informazioni sull'azienda selezionata</div>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error-box">@ErrorMessage</div>
    }
    else if (Company is not null)
    {
        <div class="details-card">
            <div class="details-row">
                <span class="label">Nome</span>
                <span class="value">@Company.Name</span>
            </div>
            <div class="details-row">
                <span class="label">Email</span>
                <span class="value">@Company.Email</span>
            </div>
            <div class="details-row">
                <span class="label">ID</span>
                <span class="value"><code>@Company.Id</code></span>
            </div>

            <div class="form-actions">
                <button class="btn btn-secondary" @onclick="GoBack">Indietro</button>
                <AuthorizeRoles Roles="@(new[] { Roles.ProjectManager, Roles.Admin })">
                    <button class="btn btn-primary" @onclick="Edit">Modifica</button>
                </AuthorizeRoles>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private CompanyDto? Company;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav,
                Roles.ProjectManager, Roles.Admin))
            return;

        try
        {
            Company = await CompanyService.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/companies");
    private void Edit() => Nav.NavigateTo($"/companies/form/{Id}");
}
