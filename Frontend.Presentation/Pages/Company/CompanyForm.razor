@page "/companies/form"
@page "/companies/form/{Id:guid}"

@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Company

@inject ICompanyService CompanyService
@inject NavigationManager Nav

<div class="form-container">
    <h2 class="title">@((Id.HasValue ? "Modifica Azienda" : "Nuova Azienda"))</h2>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else
    {
        <EditForm Model="@Model" OnValidSubmit="@SaveAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label>Nome</label>
                <InputText class="form-control" @bind-Value="Model.Name" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText class="form-control" @bind-Value="Model.Email" />
            </div>

            <div class="actions">
                <button class="btn-save" type="submit">Salva</button>
                <button class="btn-back" @onclick="GoBack">Annulla</button>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private UpdateCompanyDto Model = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var existing = await CompanyService.GetByIdAsync(Id.Value);

            if (existing != null)
            {
                Model = new UpdateCompanyDto
                {
                    Id = existing.Id,
                    Name = existing.Name,
                    Email = existing.Email,
                };
            }
        }
        else
        {
            Model = new UpdateCompanyDto
            {
                Id = Guid.NewGuid()
            };
        }

        IsLoading = false;
    }

    private async Task SaveAsync()
    {
        if (Id.HasValue)
        {
            await CompanyService.UpdateAsync(Model);
        }
        else
        {
            var createDto = new CreateCompanyDto
            {
                Name = Model.Name,
                Email = Model.Email,
            };

            await CompanyService.CreateAsync(createDto);
        }

        Nav.NavigateTo("/companies");
    }

    private void GoBack() => Nav.NavigateTo("/companies");
}