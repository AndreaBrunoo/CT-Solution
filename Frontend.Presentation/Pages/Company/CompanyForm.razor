@page "/companies/form"
@page "/companies/form/{Id:guid}"

@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Company
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers

@inject ICompanyService CompanyService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">@(Id.HasValue ? "Modifica azienda" : "Nuova azienda")</h2>
            <div class="page-subtitle">@(Id.HasValue ? "Aggiorna i dati dell'azienda" : "Aggiungi una nuova azienda cliente")</div>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else
    {
        <div class="form-card">
            <EditForm Model="@Model" OnValidSubmit="@SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="validation-summary" />

                <div class="form-group">
                    <label>Nome</label>
                    <InputText class="form-control" @bind-Value="Model.Name" placeholder="Es. Acme S.r.l." />
                    <ValidationMessage For="@(() => Model.Name)" />
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <InputText class="form-control" type="email" @bind-Value="Model.Email" placeholder="info@azienda.it" />
                    <ValidationMessage For="@(() => Model.Email)" />
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary" type="submit">@(Id.HasValue ? "Salva modifiche" : "Crea azienda")</button>
                    <button class="btn btn-secondary" type="button" @onclick="GoBack">Annulla</button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private UpdateCompanyDto Model = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav,
                Roles.ProjectManager, Roles.Admin))
            return;

        if (Id.HasValue)
        {
            var existing = await CompanyService.GetByIdAsync(Id.Value);

            if (existing != null)
            {
                Model = new UpdateCompanyDto
                {
                    Id = existing.Id,
                    Name = existing.Name,
                    Email = existing.Email,
                };
            }
        }
        else
        {
            Model = new UpdateCompanyDto
            {
                Id = Guid.NewGuid()
            };
        }

        IsLoading = false;
    }

    private async Task SaveAsync()
    {
        if (Id.HasValue)
        {
            await CompanyService.UpdateAsync(Model);
        }
        else
        {
            var createDto = new CreateCompanyDto
            {
                Name = Model.Name,
                Email = Model.Email,
            };

            await CompanyService.CreateAsync(createDto);
        }

        Nav.NavigateTo("/companies");
    }

    private void GoBack() => Nav.NavigateTo("/companies");
}
