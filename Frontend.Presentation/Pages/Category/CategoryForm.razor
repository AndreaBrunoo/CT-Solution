@page "/categories/form"
@page "/categories/form/{Id:guid}"

@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Category
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers

@inject ICategoryService CategoryService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">@(Id.HasValue ? "Modifica categoria" : "Nuova categoria")</h2>
            <div class="page-subtitle">@(Id.HasValue ? "Aggiorna la categoria" : "Crea una nuova categoria di attività")</div>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else
    {
        <div class="form-card">
            <EditForm Model="@Model" OnValidSubmit="@SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="validation-summary" />

                <div class="form-group">
                    <label>Nome</label>
                    <InputText class="form-control" @bind-Value="Model.Name" placeholder="Es. Sviluppo, Analisi, Riunioni…" />
                    <ValidationMessage For="@(() => Model.Name)" />
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary" type="submit">@(Id.HasValue ? "Salva modifiche" : "Crea categoria")</button>
                    <button class="btn btn-secondary" type="button" @onclick="GoBack">Annulla</button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private UpdateCategoryDto Model = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav,
                Roles.ProjectManager, Roles.Admin))
            return;

        if (Id.HasValue)
        {
            var existing = await CategoryService.GetByIdAsync(Id.Value);

            if (existing != null)
            {
                Model = new UpdateCategoryDto
                {
                    Id = existing.Id,
                    Name = existing.Name,
                };
            }
        }
        else
        {
            Model = new UpdateCategoryDto
            {
                Id = Guid.NewGuid()
            };
        }

        IsLoading = false;
    }

    private async Task SaveAsync()
    {
        if (Id.HasValue)
        {
            await CategoryService.UpdateAsync(Model);
        }
        else
        {
            var createDto = new CreateCategoryDto
            {
                Name = Model.Name,
            };

            await CategoryService.CreateAsync(createDto);
        }

        Nav.NavigateTo("/categories");
    }

    private void GoBack() => Nav.NavigateTo("/categories");
}
