@page "/categories/details/{Id:guid}"
@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Category
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers
@inject ICategoryService CategoryService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">Dettaglio categoria</h2>
            <div class="page-subtitle">Informazioni sulla categoria selezionata</div>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error-box">@ErrorMessage</div>
    }
    else if (Category is not null)
    {
        <div class="details-card">
            <div class="details-row">
                <span class="label">Nome</span>
                <span class="value">@Category.Name</span>
            </div>
            <div class="details-row">
                <span class="label">ID</span>
                <span class="value"><code>@Category.Id</code></span>
            </div>

            <div class="form-actions">
                <button class="btn btn-secondary" @onclick="GoBack">Indietro</button>
                <AuthorizeRoles Roles="@(new[] { Roles.ProjectManager, Roles.Admin })">
                    <button class="btn btn-primary" @onclick="Edit">Modifica</button>
                </AuthorizeRoles>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private CategoryDto? Category;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav,
                Roles.ProjectManager, Roles.Admin))
            return;

        try
        {
            Category = await CategoryService.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/categories");
    private void Edit() => Nav.NavigateTo($"/categories/form/{Id}");
}
