@page "/categories"
@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Category
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers
@inject ICategoryService CategoryService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">Categorie</h2>
            <div class="page-subtitle">Classificazione delle attività</div>
        </div>
        <div class="page-actions">
            <AuthorizeRoles Roles="@(new[] { Roles.ProjectManager, Roles.Admin })">
                <button class="btn btn-success" @onclick="Create">Nuova categoria</button>
            </AuthorizeRoles>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error-box">@ErrorMessage</div>
    }
    else if (Categories is not null)
    {
        @if (Categories.Count == 0)
        {
            <div class="empty-state">Nessuna categoria presente.</div>
        }
        else
        {
            <div class="data-card">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th class="col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (CategoryDto c in Categories)
                        {
                            <tr>
                                <td><strong>@c.Name</strong></td>
                                <td class="col-actions">
                                    <button class="btn btn-secondary btn-sm" @onclick="() => Details(c.Id)">Dettagli</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@code {
    private List<CategoryDto>? Categories;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav,
                Roles.ProjectManager, Roles.Admin))
            return;

        try
        {
            Categories = (await CategoryService.GetAllAsync())?.ToList() ?? new List<CategoryDto>();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void Details(Guid id)
    {
        Nav.NavigateTo($"/categories/details/{id}");
    }

    private void Create()
    {
        Nav.NavigateTo("/categories/form");
    }
}
