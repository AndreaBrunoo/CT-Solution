@page "/employees"
@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Employee
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers
@inject IEmployeeService EmployeeService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">Dipendenti</h2>
            <div class="page-subtitle">Anagrafe dei dipendenti con accesso al sistema</div>
        </div>
        <div class="page-actions">
            <AuthorizeRoles Roles="@(new[] { Roles.Admin })">
                <button class="btn btn-success" @onclick="Create">Nuovo dipendente</button>
            </AuthorizeRoles>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error-box">@ErrorMessage</div>
    }
    else if (Employees is not null)
    {
        @if (Employees.Count == 0)
        {
            <div class="empty-state">Nessun dipendente registrato.</div>
        }
        else
        {
            <div class="data-card">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>UserName</th>
                            <th>Email</th>
                            <th class="col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Employees)
                        {
                            <tr>
                                <td><strong>@e.UserName</strong></td>
                                <td>@e.Email</td>
                                <td class="col-actions">
                                    <button class="btn btn-secondary btn-sm" @onclick="() => Details(e.Id)">Dettagli</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@code {
    private List<EmployeeDto>? Employees;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav, Roles.Admin))
            return;

        try
        {
            Employees = (await EmployeeService.GetAllAsync())?.ToList() ?? new List<EmployeeDto>();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void Details(Guid id)
    {
        Nav.NavigateTo($"/employees/details/{id}");
    }

    private void Create()
    {
        Nav.NavigateTo("/employees/form");
    }
}
