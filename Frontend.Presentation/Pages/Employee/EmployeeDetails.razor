@page "/employees/details/{Id:guid}"
@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Employee
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers
@inject IEmployeeService EmployeeService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">Dettaglio dipendente</h2>
            <div class="page-subtitle">Informazioni sul dipendente selezionato</div>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error-box">@ErrorMessage</div>
    }
    else if (Employee is not null)
    {
        <div class="details-card">
            <div class="details-row">
                <span class="label">UserName</span>
                <span class="value">@Employee.UserName</span>
            </div>
            <div class="details-row">
                <span class="label">Email</span>
                <span class="value">@Employee.Email</span>
            </div>
            <div class="details-row">
                <span class="label">ID</span>
                <span class="value"><code>@Employee.Id</code></span>
            </div>

            <div class="form-actions">
                <button class="btn btn-secondary" @onclick="GoBack">Indietro</button>
                <AuthorizeRoles Roles="@(new[] { Roles.Admin })">
                    <button class="btn btn-primary" @onclick="Edit">Modifica</button>
                </AuthorizeRoles>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private EmployeeDto? Employee;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav, Roles.Admin))
            return;

        try
        {
            Employee = await EmployeeService.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/employees");
    private void Edit() => Nav.NavigateTo($"/employees/form/{Id}");
}
