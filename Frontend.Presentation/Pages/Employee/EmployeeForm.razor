@page "/employees/form"
@page "/employees/form/{Id:guid}"

@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Employee
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers

@inject IEmployeeService EmployeeService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">@(Id.HasValue ? "Modifica dipendente" : "Nuovo dipendente")</h2>
            <div class="page-subtitle">@(Id.HasValue ? "Aggiorna i dati del dipendente" : "Aggiungi un nuovo dipendente al sistema")</div>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else
    {
        <div class="form-card">
            <EditForm Model="@Model" OnValidSubmit="@SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="validation-summary" />

                <div class="form-group">
                    <label>UserName</label>
                    <InputText class="form-control" @bind-Value="Model.UserName" placeholder="es. mario.rossi" />
                    <ValidationMessage For="@(() => Model.UserName)" />
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <InputText class="form-control" type="email" @bind-Value="Model.Email" placeholder="mario.rossi@azienda.it" />
                    <ValidationMessage For="@(() => Model.Email)" />
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary" type="submit">@(Id.HasValue ? "Salva modifiche" : "Crea dipendente")</button>
                    <button class="btn btn-secondary" type="button" @onclick="GoBack">Annulla</button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private UpdateEmployeeDto Model = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav, Roles.Admin))
            return;

        if (Id.HasValue)
        {
            var existing = await EmployeeService.GetByIdAsync(Id.Value);

            if (existing != null)
            {
                Model = new UpdateEmployeeDto
                {
                    Id = existing.Id,
                    UserName = existing.UserName,
                    Email = existing.Email,
                };
            }
        }
        else
        {
            Model = new UpdateEmployeeDto
            {
                Id = Guid.NewGuid()
            };
        }

        IsLoading = false;
    }

    private async Task SaveAsync()
    {
        if (Id.HasValue)
        {
            await EmployeeService.UpdateAsync(Model);
        }

        Nav.NavigateTo("/employees");
    }

    private void GoBack() => Nav.NavigateTo("/employees");
}
