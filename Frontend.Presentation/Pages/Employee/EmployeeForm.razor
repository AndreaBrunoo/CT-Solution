@page "/employees/form"
@page "/employees/form/{Id:guid}"

@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Employee
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers

@inject IEmployeeService EmployeeService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="form-container">
    <h2 class="title">@((Id.HasValue ? "Modifica Dipendente" : "Nuovo Dipendente"))</h2>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else
    {
        <EditForm Model="@Model" OnValidSubmit="@SaveAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label>UserName</label>
                <InputText class="form-control" @bind-Value="Model.UserName" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText class="form-control" @bind-Value="Model.Email" />
            </div>

            <div class="actions">
                <button class="btn-save" type="submit">Salva</button>
                <button class="btn-back" @onclick="GoBack">Annulla</button>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private UpdateEmployeeDto Model = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav, Roles.Admin))
            return;

        if (Id.HasValue)
        {
            var existing = await EmployeeService.GetByIdAsync(Id.Value);

            if (existing != null)
            {
                Model = new UpdateEmployeeDto
                {
                    Id = existing.Id,
                    UserName = existing.UserName,
                    Email = existing.Email,
                };
            }
        }
        else
        {
            Model = new UpdateEmployeeDto
            {
                Id = Guid.NewGuid()
            };
        }

        IsLoading = false;
    }

    private async Task SaveAsync()
    {
        if (Id.HasValue)
        {
            await EmployeeService.UpdateAsync(Model);
        }

        Nav.NavigateTo("/employees");
    }

    private void GoBack() => Nav.NavigateTo("/employees");
}
