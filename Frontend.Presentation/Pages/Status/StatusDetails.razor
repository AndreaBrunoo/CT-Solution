@page "/statuses/details/{Id:guid}"
@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Status
@inject IStatusService StatusService
@inject NavigationManager Nav

<div class="details-container">
    <h2 class="title">Dettaglio Stato</h2>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error">@ErrorMessage</div>
    }
    else if (Status is not null)
    {
        <div class="details-card">

            <div class="details-row">
                <span class="label">Nome:</span>
                <span class="value">@Status.Name</span>
            </div>

            <div class="details-row">
                <span class="label">ID:</span>
                <span class="value">@Status.Id</span>
            </div>

            <div class="actions">
                <button class="btn-back" @onclick="GoBack">← Indietro</button>
                <button class="btn-edit" @onclick="Edit">Modifica</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private StatusDto? Status;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Status = await StatusService.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/statuses");
    private void Edit() => Nav.NavigateTo($"/statuses/form/{Id}");
}
