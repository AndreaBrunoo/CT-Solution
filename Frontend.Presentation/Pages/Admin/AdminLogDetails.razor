@page "/admin/logs/details/{Id:guid}"
@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Log
@inject IUserService UserService
@inject NavigationManager Nav
@inject ILogService LogService

<div class="details-container">
    <h2 class="title">Dettaglio Log</h2>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (!IsAdmin)
    {
        <div class="error">Accesso negato: solo gli amministratori possono visualizzare questa pagina.</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error">@ErrorMessage</div>
    }
    else if (Log is not null)
    {
        <div class="details-card @(Log.Success ? "card-ok" : "card-error")">

            <div class="details-row">
                <span class="label">Timestamp:</span>
                <span class="value">@Log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</span>
            </div>

            <div class="details-row">
                <span class="label">Azione:</span>
                <span class="value">@Log.Action</span>
            </div>

            <div class="details-row">
                <span class="label">Entità:</span>
                <span class="value">@Log.Entity</span>
            </div>

            <div class="details-row">
                <span class="label">ID Entità:</span>
                <span class="value">@Log.EntityId</span>
            </div>

            <div class="details-row">
                <span class="label">Utente:</span>
                <span class="value">@Log.UserEmail</span>
            </div>

            <div class="details-row">
                <span class="label">Esito:</span>
                <span class="value">@((Log.Success ? "OK" : "Errore"))</span>
            </div>

            @if (!Log.Success && Log.ErrorMessage is not null)
            {
                <div class="details-row">
                    <span class="label">Errore:</span>
                    <span class="value error-text">@Log.ErrorMessage</span>
                </div>
            }

            <div class="actions">
                <button class="btn-back" @onclick="GoBack">← Indietro</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private LogDto? Log;
    private bool IsLoading = true;
    private bool IsAdmin = false;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var user = await UserService.GetCurrentUserAsync();
            IsAdmin = user?.Roles.Contains("Admin") ?? false;

            if (!IsAdmin)
            {
                IsLoading = false;
                return;
            }

            Log = await LogService.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/admin/logs");
}