@page "/admin/logs"
@using Frontend.Domain.Contracts
@using Frontend.Domain.Dtos.Log
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@using Frontend.Presentation.Helpers
@inject ILogService LogService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">Log di sistema</h2>
            <div class="page-subtitle">Tutte le operazioni registrate sull'applicazione</div>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error-box">@ErrorMessage</div>
    }
    else
    {
        <div class="filters">
            <input class="form-control" placeholder="Filtra per utente…" @bind="FilterUser" @bind:event="oninput" />
            <input class="form-control" placeholder="Filtra per entità…" @bind="FilterEntity" @bind:event="oninput" />
            <button class="btn btn-primary" @onclick="ApplyFilters">Filtra</button>
            <button class="btn btn-ghost" @onclick="ResetFilters">Reset</button>
        </div>

        @if (FilteredLogs.Count == 0)
        {
            <div class="empty-state">Nessun log corrisponde ai filtri impostati.</div>
        }
        else
        {
            <div class="data-card">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>Azione</th>
                            <th>Entità</th>
                            <th>Utente</th>
                            <th>Esito</th>
                            <th class="col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in FilteredLogs)
                        {
                            <tr class="@(log.Success ? "row-ok" : "row-error")">
                                <td><strong>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</strong></td>
                                <td>@log.Action</td>
                                <td>@($"{log.Entity} ({log.EntityId})")</td>
                                <td>@log.UserEmail</td>
                                <td>
                                    @if (log.Success)
                                    {
                                        <span class="badge badge-success">OK</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Errore</span>
                                    }
                                </td>
                                <td class="col-actions">
                                    <button class="btn btn-secondary btn-sm" @onclick="() => Details(log.Id)">Dettagli</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@code {
    private List<LogDto> Logs = new();
    private List<LogDto> FilteredLogs = new();

    private bool IsLoading = true;
    private string? ErrorMessage;

    private string FilterUser = string.Empty;
    private string FilterEntity = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav, Roles.Admin))
            return;

        try
        {
            Logs = (await LogService.GetAllAsync())?.ToList() ?? new List<LogDto>();
            FilteredLogs = Logs;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ApplyFilters()
    {
        FilteredLogs = Logs
            .Where(l =>
                (string.IsNullOrWhiteSpace(FilterUser) ||
                (l.UserEmail?.Contains(FilterUser,
                StringComparison.OrdinalIgnoreCase) ?? false)) &&
                (string.IsNullOrWhiteSpace(FilterEntity) ||
                l.Entity.Contains(FilterEntity,
                StringComparison.OrdinalIgnoreCase))
            )
            .ToList();
    }

    private void ResetFilters()
    {
        FilterUser = string.Empty;
        FilterEntity = string.Empty;
        FilteredLogs = Logs;
    }

    private void Details(Guid id)
    {
        Nav.NavigateTo($"/admin/logs/details/{id}");
    }
}
