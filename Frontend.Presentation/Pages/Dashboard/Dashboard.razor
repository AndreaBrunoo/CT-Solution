@using Frontend.Domain.Dtos.Dashboard;
@using Frontend.Domain.Contracts;

@page "/Dashboard"
@inject IDashboardService DashboardService
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">Dashboard</h2>
            <div class="page-subtitle">Panoramica delle tue attività recenti</div>
        </div>
        <div class="page-actions">
            <button class="btn btn-secondary" @onclick="Reload" disabled="@IsLoading">Aggiorna</button>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento dati…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error-box">
            <strong>Errore nel caricamento della dashboard.</strong>
            <div class="error-detail">@ErrorMessage</div>
            <div class="error-hint">
                Verifica che l'API sia avviata su <code>http://localhost:5203</code> e che il token sia valido.
            </div>
        </div>
    }
    else if (Data is not null)
    {
        <div class="kpi-grid">
            <button class="kpi-card kpi-clickable" @onclick="@(() => Nav.NavigateTo("/worklog"))">
                <div class="kpi-value">@Data.MyHoursWeek</div>
                <div class="kpi-label">Ore ultime 2 settimane</div>
            </button>

            <button class="kpi-card kpi-clickable" @onclick="@(() => Nav.NavigateTo("/worklog"))">
                <div class="kpi-value">@Data.MyWorkLogsCount</div>
                <div class="kpi-label">WorkLog totali</div>
            </button>

            <button class="kpi-card kpi-clickable" @onclick="@(() => Nav.NavigateTo("/projects"))">
                <div class="kpi-value">@Data.ProjectsCount</div>
                <div class="kpi-label">Progetti</div>
            </button>

            <button class="kpi-card kpi-clickable" @onclick="@(() => Nav.NavigateTo("/companies"))">
                <div class="kpi-value">@Data.CompaniesCount</div>
                <div class="kpi-label">Aziende</div>
            </button>
        </div>

        <div class="page-section">
            <h3 class="section-title">WorkLog recenti</h3>

            <div class="data-card">
                @if (Data.RecentWorkLogs is null || Data.RecentWorkLogs.Count == 0)
                {
                    <div class="empty-state">Nessun WorkLog recente. Inizia creandone uno dalla sezione WorkLog.</div>
                }
                else
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Data</th>
                                <th>Descrizione</th>
                                <th class="col-actions">Ore</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in Data.RecentWorkLogs)
                            {
                                <tr>
                                    <td>@w.Date.ToString("dd/MM/yyyy")</td>
                                    <td class="text-muted">@w.Description</td>
                                    <td class="col-actions">
                                        <span class="badge badge-brand">@w.HoursCounter h</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
</div>

@code {
    private DashboardDto? Data;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task Reload()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        try
        {
            Data = await DashboardService.GetKpiAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}
