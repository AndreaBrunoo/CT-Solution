@using Frontend.Domain.Dtos.Dashboard;
@using Frontend.Domain.Contracts;

@page "/Dashboard"
@inject IDashboardService DashboardService
@inject NavigationManager Nav

<div class="dashboard-container">
    <div class="dashboard-header">
        <h2 class="dashboard-title">Dashboard</h2>
        <button class="btn-refresh" @onclick="Reload" disabled="@IsLoading" title="Ricarica">
            ⟳
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error">
            <strong>Errore nel caricamento della dashboard.</strong>
            <div class="error-detail">@ErrorMessage</div>
            <div class="error-hint">
                Verifica che l'API sia avviata su <code>http://localhost:5203</code> e che il token sia valido.
            </div>
        </div>
    }
    else if (Data is not null)
    {
        <div class="kpi-grid">

            <a class="kpi-card kpi-clickable" @onclick="@(() => Nav.NavigateTo("/worklog"))">
                <div class="kpi-icon">⏱️</div>
                <div class="kpi-value">@Data.MyHoursWeek</div>
                <div class="kpi-label">Ore ultime 2 settimane</div>
            </a>

            <a class="kpi-card kpi-clickable" @onclick="@(() => Nav.NavigateTo("/worklog"))">
                <div class="kpi-icon">📝</div>
                <div class="kpi-value">@Data.MyWorkLogsCount</div>
                <div class="kpi-label">WorkLog totali</div>
            </a>

            <a class="kpi-card kpi-clickable" @onclick="@(() => Nav.NavigateTo("/projects"))">
                <div class="kpi-icon">📁</div>
                <div class="kpi-value">@Data.ProjectsCount</div>
                <div class="kpi-label">Progetti</div>
            </a>

            <a class="kpi-card kpi-clickable" @onclick="@(() => Nav.NavigateTo("/companies"))">
                <div class="kpi-icon">🏢</div>
                <div class="kpi-value">@Data.CompaniesCount</div>
                <div class="kpi-label">Aziende</div>
            </a>

        </div>

        <h3 class="section-title">WorkLog recenti</h3>

        <div class="recent-list">
            @if (Data.RecentWorkLogs is null || Data.RecentWorkLogs.Count == 0)
            {
                <div class="recent-empty">Nessun WorkLog recente.</div>
            }
            else
            {
                @foreach (var w in Data.RecentWorkLogs)
                {
                    <div class="recent-item">
                        <div class="recent-left">
                            <div class="recent-date">@w.Date.ToString("dd/MM/yyyy")</div>
                            <div class="recent-desc">@w.Description</div>
                        </div>
                        <div class="recent-hours">@w.HoursCounter h</div>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private DashboardDto? Data;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task Reload()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        try
        {
            Data = await DashboardService.GetKpiAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

}