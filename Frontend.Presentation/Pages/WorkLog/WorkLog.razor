@using Frontend.Domain.Contracts;
@using Frontend.Domain.Dtos.WorkLog;
@using Frontend.Domain.Constants;
@using Frontend.Application.Services;
@using Frontend.Presentation.Helpers;

@page "/worklog"
@inject IWorkLogService WorkLogService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <div>
            <h2 class="page-title">I miei WorkLog</h2>
            <div class="page-subtitle">Le ore e le attività che hai registrato</div>
        </div>
        <div class="page-actions">
            <AuthorizeRoles Roles="@(new[] { Roles.User, Roles.ProjectManager, Roles.Admin })">
                <button class="btn btn-success" @onclick="CreateNew">Nuovo WorkLog</button>
            </AuthorizeRoles>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="loading">Caricamento…</div>
    }
    else if (ErrorMessage is not null)
    {
        <div class="error-box">@ErrorMessage</div>
    }
    else if (Data is not null)
    {
        @if (Data.Count == 0)
        {
            <div class="empty-state">Nessun WorkLog registrato. Inizia creandone uno.</div>
        }
        else
        {
            <div class="data-card">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Progetto</th>
                            <th>Categoria</th>
                            <th>Ore</th>
                            <th>Stato</th>
                            <th class="col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var w in Data)
                        {
                            <tr>
                                <td><strong>@w.Date.ToString("dd/MM/yyyy")</strong></td>
                                <td>@w.ProjectName</td>
                                <td>@w.CategoryName</td>
                                <td><span class="badge badge-brand">@w.HoursCounter h</span></td>
                                <td><span class="badge">@w.StatusName</span></td>
                                <td class="col-actions">
                                    <button class="btn btn-secondary btn-sm" @onclick="() => GoToDetails(w.Id)">Dettagli</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@code {
    private IReadOnlyList<WorkLogDto>? Data;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthGuard.EnsureRoleAsync(CurrentUser, Nav,
                Roles.User, Roles.ProjectManager, Roles.Admin))
            return;

        try
        {
            Data = await WorkLogService.GetMineAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void GoToDetails(Guid id)
    {
        Nav.NavigateTo($"/worklog/details/{id}");
    }

    private void CreateNew()
    {
        Nav.NavigateTo("/worklog/form");
    }
}
