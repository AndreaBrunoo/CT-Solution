@inherits LayoutComponentBase
@using Frontend.Domain.Contracts
@using Frontend.Application.Services
@inject ITokenProvider TokenProvider
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<div class="app-shell">
    <NavMenu />

    <main class="content">
        @Body
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // All'avvio (anche dopo F5), se c'è un token valido in localStorage
        // proviamo a idratare l'utente corrente per non dover rifare il login.
        if (!CurrentUser.IsAuthenticated)
            await CurrentUser.TryHydrateAsync();
    }
}
