@using Frontend.Domain.Contracts
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@inject NavigationManager Nav
@inject CurrentUserService CurrentUser

<header class="topbar topbar-app">
    <NavLink class="brand-link" href="Dashboard" Match="NavLinkMatch.All" title="Vai alla Dashboard">
        <img class="brand-logo" src="logo-ct-solution.png" alt="CT Solution" />
    </NavLink>

    <nav class="topnav" aria-label="Navigazione principale">
        <NavLink class="topnav-link" href="Dashboard" Match="NavLinkMatch.All">
            <button type="button" class="topnav-btn">Dashboard</button>
        </NavLink>

        <NavLink class="topnav-link" href="worklog">
            <button type="button" class="topnav-btn">WorkLog</button>
        </NavLink>

        @if (CurrentUser.IsInAnyRole(Roles.ProjectManager, Roles.Admin))
        {
            <NavLink class="topnav-link" href="projects">
                <button type="button" class="topnav-btn">Progetti</button>
            </NavLink>

            <NavLink class="topnav-link" href="companies">
                <button type="button" class="topnav-btn">Aziende</button>
            </NavLink>

            <NavLink class="topnav-link" href="categories">
                <button type="button" class="topnav-btn">Categorie</button>
            </NavLink>

            <NavLink class="topnav-link" href="statuses">
                <button type="button" class="topnav-btn">Stati</button>
            </NavLink>
        }

        @if (CurrentUser.IsInRole(Roles.Admin))
        {
            <NavLink class="topnav-link" href="employees">
                <button type="button" class="topnav-btn">Dipendenti</button>
            </NavLink>

            <NavLink class="topnav-link" href="admin/logs">
                <button type="button" class="topnav-btn">Log</button>
            </NavLink>
        }
    </nav>

    <div class="topbar-spacer"></div>

    <div class="topbar-user-menu">
        <div class="topbar-user" title="@CurrentUser.Current?.Email">
            <div class="topbar-avatar">@Initials</div>
            <div class="topbar-user-info">
                <span class="topnav-label" style="display:block">@(string.IsNullOrWhiteSpace(CurrentUser.Current?.Email)
                                        ? "Utente" : CurrentUser.Current!.Email)</span>
                <span class="topbar-user-role">@PrimaryRole</span>
            </div>
        </div>
        <button type="button" class="btn topbar-logout" @onclick="Logout" title="Esci" aria-label="Esci">
            Esci
        </button>
    </div>
</header>

@code {
    private string Initials = "CT";
    private string PrimaryRole = "";

    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUser.IsAuthenticated)
        {
            try { await CurrentUser.TryHydrateAsync(); }
            catch { /* fallback silenzioso */ }
        }

        UpdateUserChip();
    }

    private void UpdateUserChip()
    {
        var email = CurrentUser.Current?.Email ?? "";
        Initials = BuildInitials(email);
        PrimaryRole = CurrentUser.IsInRole(Roles.Admin) ? "Amministratore"
                    : CurrentUser.IsInRole(Roles.ProjectManager) ? "Project Manager"
                    : "Utente";
    }

    private static string BuildInitials(string email)
    {
        if (string.IsNullOrWhiteSpace(email)) return "CT";
        var local = email.Split('@')[0];
        var parts = local.Split(new[] { '.', '_', '-', '+' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2 && parts[0].Length > 0 && parts[1].Length > 0)
            return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
        if (local.Length >= 2) return local.Substring(0, 2).ToUpperInvariant();
        return local.ToUpperInvariant();
    }

    private async Task Logout()
    {
        await CurrentUser.ClearAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }
}
