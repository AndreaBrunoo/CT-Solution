                    </svg>
                    <span class="nav-label">Progetti</span>
                </div>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link nav-volume-btn" href="companies">
                <div class="nav-link-main">
                    <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M14.763.075A.5.5 0 0 1 15 .5v15a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5V14h-1v1.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V10a.5.5 0 0 1 .341-.467l2.828-1.122a.5.5 0 1 0-.447-.894l-2.829 1.122A1.5 1.5 0 0 0 0 10v5.5A1.5 1.5 0 0 0 1.5 17h13a1.5 1.5 0 0 0 1.5-1.5v-15A1.5 1.5 0 0 0 14.5 0h-3a.5.5 0 0 0-.5.5v.075H10V.5A.5.5 0 0 0 9.5 0h-6a.5.5 0 0 0-.5.5V8h-.5A1.5 1.5 0 0 0 .5 9.5V10h.5v-.5A.5.5 0 0 1 1.5 9h.5V8H2V.5A1.5 1.5 0 0 1 3.5 0h6A1.5 1.5 0 0 1 11 .5V8h.5A1.5 1.5 0 0 1 13 9.5v.5h.5a.5.5 0 0 1 .5.5v3.5a.5.5 0 0 1-.5.5H14V.5a.5.5 0 0 1 .5-.5h.263zM10 3v1.5a.5.5 0 0 0 .5.5h.5V3h-1z" />
