@using Frontend.Domain.Contracts
@using Frontend.Domain.Constants
@using Frontend.Application.Services
@inject NavigationManager Nav
@inject CurrentUserService CurrentUser

<div class="sidebar-brand">
    <NavLink class="brand-link" href="Dashboard" Match="NavLinkMatch.All" title="Vai alla Dashboard">
        <img class="brand-logo" src="logo-ct-solution.png" alt="CT Solution" />
    </NavLink>
    <span class="brand-email">@DisplayEmail</span>
</div>

<nav class="sidebar-nav">
    @* Voci sempre visibili (Dashboard, WorkLog) *@
