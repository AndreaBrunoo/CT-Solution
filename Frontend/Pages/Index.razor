@page "/"
@using Blazored.LocalStorage
@inject ILocalStorageService LocalStorage
@inject NavigationManager Nav
@inject Frontend.Services.DashboardService DashboardService

@code {
    private Frontend.Dtos.Dashboard.DashboardDto? kpi;
    private string[]? chartLabels;
    private int[]? chartData;

    protected override async Task OnInitializedAsync()
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");

        if (string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        try
        {
            kpi = await DashboardService.GetKpiAsync();
            PrepareChartData();
        }
        catch
        {
            kpi = new Frontend.Dtos.Dashboard.DashboardDto { RecentWorkLogs = new List<Frontend.Dtos.WorkLog.WorkLogDto>() };
            PrepareChartData();
        }
    }

    private void PrepareChartData()
    {
        if (kpi?.RecentWorkLogs == null || !kpi.RecentWorkLogs.Any())
        {
            chartLabels = new string[0];
            chartData = new int[0];
            return;
        }

        var grouped = kpi.RecentWorkLogs
            .GroupBy(w => w.Date)
            .OrderBy(g => g.Key)
            .Select(g => new { Date = g.Key, Hours = g.Sum(x => x.HoursCounter) })
            .ToList();

        chartLabels = grouped.Select(g => g.Date.ToString("MM-dd")).ToArray();
        chartData = grouped.Select(g => g.Hours).ToArray();
    }
}

<PageHeader Title="Dashboard" Subtitle="Riepilogo rapido">
    <Actions>
        <a class="btn btn-sm btn-primary me-2" href="/worklog/my">Le mie attività</a>
        <a class="btn btn-sm btn-outline-light" href="/projects">Progetti</a>
    </Actions>
</PageHeader>

<div class="row">
    <div class="col-md-3">
        <div class="card kpi-card mb-3" @onclick='() => Nav.NavigateTo("/worklog/my")'>
            <div class="card-body">
                <div class="kpi-icon bg-blue"><i class="bi bi-clock-history"></i></div>
                <div>
                    <div class="kpi-label">Ore (ultimi 7 giorni)</div>
                    <div class="kpi-value"><AnimatedNumber Value="(kpi?.MyHoursWeek) ?? 0" /></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card mb-3" @onclick='() => Nav.NavigateTo("/worklog/my")'>
            <div class="card-body">
                <div class="kpi-icon bg-green"><i class="bi bi-list-check"></i></div>
                <div>
                    <div class="kpi-label">I miei worklog</div>
                    <div class="kpi-value"><AnimatedNumber Value="(kpi?.MyWorkLogsCount) ?? 0" /></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card mb-3" @onclick='() => Nav.NavigateTo("/projects")'>
            <div class="card-body">
                <div class="kpi-icon bg-violet"><i class="bi bi-folder2-open"></i></div>
                <div>
                    <div class="kpi-label">Progetti</div>
                    <div class="kpi-value"><AnimatedNumber Value="(kpi?.ProjectsCount) ?? 0" /></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card mb-3" @onclick='() => Nav.NavigateTo("/companies")'>
            <div class="card-body">
                <div class="kpi-icon bg-yellow"><i class="bi bi-building"></i></div>
                <div>
                    <div class="kpi-label">Aziende</div>
                    <div class="kpi-value"><AnimatedNumber Value="(kpi?.CompaniesCount) ?? 0" /></div>
                </div>
            </div>
        </div>
    </div>
</div>

<h4 class="mt-4">Ultimi worklog</h4>
<div class="mt-3 mb-4">
    <!-- Chart showing hours by date -->
    @if (chartLabels != null && chartData != null)
    {
        <SimpleChart CanvasId="dashboardChart" Labels="chartLabels" Data="chartData" />
    }
</div>
@if (kpi == null)
{
    <LoadingSpinner />
}
else if (kpi.RecentWorkLogs == null || !kpi.RecentWorkLogs.Any())
{
    <EmptyState Title="Nessun worklog recente" Description="Non ci sono worklog recenti." Icon="<i class='bi bi-clock-history'></i>" />
}
else
{
    <DataTable Items="kpi.RecentWorkLogs">
        <HeaderTemplate>
            <tr>
                <th>Data</th>
                <th>Progetto</th>
                <th>Ore</th>
                <th>Dipendente</th>
                <th></th>
            </tr>
        </HeaderTemplate>
        <RowTemplate Context="w">
            <td>@w.Date.ToString("yyyy-MM-dd")</td>
            <td>@(w.ProjectName ?? "-")</td>
            <td>@w.HoursCounter</td>
            <td>@(w.EmployeeName ?? "-")</td>
            <td><a class="btn btn-sm btn-secondary" href="/worklog/details/@w.Id">Dettagli</a></td>
        </RowTemplate>
    </DataTable>
}
