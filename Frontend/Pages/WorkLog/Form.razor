@using Frontend.Dtos.WorkLog;
@page "/worklog/form"
@page "/worklog/form/{Id:guid}"

@inject Frontend.Services.WorkLogService WorkLogService
@inject NavigationManager Nav

<PageHeader Title="@(Id.HasValue ? "Modifica WorkLog" : "Nuovo WorkLog")" />

@if (isLoading)
{
    <p>Caricamento...</p>
}
else
{
    <EditForm Model="model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Nome</label>
            <InputText class="form-control" @bind-Value="model.Name" />
        </div>

        <div class="mb-3">
            <label class="form-label">Descrizione</label>
            <InputText class="form-control" @bind-Value="model.Description" />
        </div>

        <div class="mb-3">
            <label class="form-label">Ore</label>
            <InputNumber class="form-control" @bind-Value="model.HoursCounter" />
        </div>

        <div class="mb-3">
            <label class="form-label">Data</label>
            <InputDate class="form-control" @bind-Value="model.DateTime" />
        </div>

        <div class="mb-3">
            <label class="form-label">Progetto</label>
            <InputText class="form-control" @bind-Value="model.IdProjectString" />
        </div>

        <div class="mb-3">
            <label class="form-label">Categoria</label>
            <InputText class="form-control" @bind-Value="model.IdCategoryString" />
        </div>

        <div class="mb-3">
            <label class="form-label">Stato</label>
            <InputText class="form-control" @bind-Value="model.IdStatusString" />
        </div>

        <button class="btn btn-primary">Salva</button>
        <a class="btn btn-secondary ms-2" href="/worklog/my">Annulla</a>
    </EditForm>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool isLoading = true;

    private WorkLogFormModel model = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var existing = await WorkLogService.GetByIdAsync(Id.Value);

            if (existing != null)
            {
                model = new WorkLogFormModel
                {
                    Id = existing.Id,
                    Name = existing.Name,
                    Description = existing.Description,
                    HoursCounter = existing.HoursCounter,
                    DateTime = existing.Date.ToDateTime(TimeOnly.MinValue),
                    IdProjectString = existing.IdProject.ToString(),
                    IdEmployeeString = existing.IdEmployee.ToString(),
                    IdCategoryString = existing.IdCategory.ToString(),
                    IdStatusString = existing.IdStatus.ToString()
                };
            }
        }
        else
        {
            model = new WorkLogFormModel
            {
                Id = Guid.NewGuid(),
                DateTime = DateTime.Today
            };
        }

        isLoading = false;
    }

    private async Task SaveAsync()
    {
        if (Id.HasValue)
        {
            var dto = new UpdateWorkLogDto
            {
                Id = model.Id,
                Name = model.Name,
                Description = model.Description,
                HoursCounter = model.HoursCounter,
                Date = DateOnly.FromDateTime(model.DateTime),
                IdProject = Guid.Parse(model.IdProjectString),
                IdEmployee = Guid.Parse(model.IdEmployeeString),
                IdCategory = Guid.Parse(model.IdCategoryString),
                IdStatus = Guid.Parse(model.IdStatusString)
            };

            await WorkLogService.UpdateAsync(dto);
        }
        else
        {
            var dto = new CreateWorkLogDto
            {
                Name = model.Name,
                Description = model.Description,
                HoursCounter = model.HoursCounter,
                Date = DateOnly.FromDateTime(model.DateTime),
                IdProject = Guid.Parse(model.IdProjectString),
                IdEmployee = Guid.Parse(model.IdEmployeeString),
                IdCategory = Guid.Parse(model.IdCategoryString),
                IdStatus = Guid.Parse(model.IdStatusString)
            };

            await WorkLogService.CreateAsync(dto);
        }

        Nav.NavigateTo("/worklog/my");
    }

    public class WorkLogFormModel
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public int HoursCounter { get; set; }
        public DateTime DateTime { get; set; }

        public string IdProjectString { get; set; } = "";
        public string IdEmployeeString { get; set; } = "";
        public string IdCategoryString { get; set; } = "";
        public string IdStatusString { get; set; } = "";
    }
}