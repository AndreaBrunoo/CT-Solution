@page "/worklog/details/{Id:guid}"
@inject Frontend.Services.WorkLogService WorkLogService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageHeader Title="Dettaglio WorkLog" Subtitle="@($"ID: {Id}")" />

@if (isLoading)
{
    <p>Caricamento...</p>
}
else if (worklog == null)
{
    <p>WorkLog non trovato.</p>
}
else
{
    <dl class="row">
        <dt class="col-sm-3">Data</dt>
        <dd class="col-sm-9">@worklog.Date.ToString("yyyy-MM-dd")</dd>

        <dt class="col-sm-3">Progetto</dt>
        <dd class="col-sm-9">@worklog.ProjectName</dd>

        <dt class="col-sm-3">Ore</dt>
        <dd class="col-sm-9">@worklog.HoursCounter</dd>

        <dt class="col-sm-3">Note</dt>
        <dd class="col-sm-9">@worklog.Description</dd>

        <dt class="col-sm-3">Dipendente</dt>
        <dd class="col-sm-9">@worklog.EmployeeName</dd>

        <dt class="col-sm-3">Categoria</dt>
        <dd class="col-sm-9">@worklog.CategoryName</dd>

        <dt class="col-sm-3">Stato</dt>
        <dd class="col-sm-9">@worklog.StatusName</dd>
    </dl>

    <button class="btn btn-secondary" @onclick="GoBack">Indietro</button>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool isLoading = true;
    private Frontend.Dtos.WorkLog.WorkLogDto? worklog;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            worklog = await WorkLogService.GetByIdAsync(Id);
        }
        catch
        {
            worklog = null;
        }

        isLoading = false;
    }

    private async Task GoBack()
    {
        await JS.InvokeVoidAsync("goBack");
    }
}