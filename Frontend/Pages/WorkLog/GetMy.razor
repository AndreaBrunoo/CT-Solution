@page "/worklog/my"
@inject Frontend.Services.WorkLogService WorkLogService

<PageHeader Title="WorkLog - Miei" Subtitle="Elenco dei tuoi worklog">
    <Actions>
        <a class="btn btn-primary mb-3" href="/worklog/form">Nuovo worklog</a>
    </Actions>
</PageHeader>

@if (worklogs == null)
{
    <p>Caricamento...</p>
}
else if (!worklogs.Any())
{
    <p>Nessun worklog trovato.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Data</th>
                <th>Progetto</th>
                <th>Ore</th>
                <th>Note</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var w in worklogs)
            {
                <tr>
                    <td>@w.Date.ToString("yyyy-MM-dd")</td>
                    <td>@(w.ProjectName ?? "-")</td>
                    <td>@w.HoursCounter</td>
                    <td>@w.Description</td>
                    <td>
                        <a class="btn btn-sm btn-secondary" href="/worklog/details/@w.Id">Dettagli</a>
                        <a class="btn btn-sm btn-warning" href="/worklog/form/@w.Id">Modifica</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Frontend.Dtos.WorkLog.WorkLogDto>? worklogs;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            worklogs = await WorkLogService.GetMineAsync();
            worklogs ??= new List<Frontend.Dtos.WorkLog.WorkLogDto>();
        }
        catch
        {
            worklogs = new List<Frontend.Dtos.WorkLog.WorkLogDto>();
        }
    }
}