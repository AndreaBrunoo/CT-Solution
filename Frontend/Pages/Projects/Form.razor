@page "/projects/form"
@page "/projects/form/{Id:guid}"

@using System
@using Microsoft.AspNetCore.Components

@code {
    [Parameter]
    public Guid? Id { get; set; }
}

<PageHeader Title="@(Id.HasValue ? "Modifica Progetto" : "Nuovo Progetto")" />
<form>
    <div class="mb-3">
        <label class="form-label">Nome</label>
        <input class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Azienda</label>
        <select class="form-select"><option>Azienda demo</option></select>
    </div>
    <div class="mb-3">
        <label class="form-label">Tariffa</label>
        <input class="form-control" type="number" step="0.01" />
    </div>
    <button class="btn btn-primary">Salva</button>
    <a class="btn btn-secondary ms-2" href="/projects">Annulla</a>
</form>