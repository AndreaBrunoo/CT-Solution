@using Blazored.LocalStorage
@using Frontend.Services
@using Frontend.Dtos.User

@page "/login"
@layout EmptyLayout
@inject UserService Auth
@inject ILocalStorageService LocalStorage
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-card">
        <div class="login-brand">
            <div class="login-logo">CT</div>
            <h1 class="login-title">Bentornato</h1>
            <p class="login-subtitle">Accedi al tuo account per continuare</p>
        </div>

        <EditForm Model="model" OnValidSubmit="DoLogin" class="login-form">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email"
                           class="form-control"
                           type="email"
                           placeholder="nome@gmail.com"
                           autocomplete="email"
                           @bind-Value="model.Email" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <InputText id="password"
                           class="form-control"
                           type="password"
                           placeholder="••••••••"
                           autocomplete="current-password"
                           @bind-Value="model.Password" />
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert-error">@ErrorMessage</div>
            }

            <button type="submit" class="btn-login" disabled="@IsBusy">
                @if (IsBusy)
                {
                    <span class="spinner"></span>
                    <span>Accesso in corso…</span>
                }
                else
                {
                    <span>Accedi</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            <span>CT Solution · v1.0</span>
        </div>
    </div>
</div>

@code {
    private LoginDto model = new();
    private string ErrorMessage = string.Empty;
    private bool IsBusy = false;

    private async Task DoLogin()
    {
        ErrorMessage = string.Empty;
        IsBusy = true;

        try
        {
            var result = await Auth.LoginAsync(model);

            if (result?.Token is not null)
            {
                await LocalStorage.SetItemAsync("authToken", result.Token);
                Nav.NavigateTo("/");
            }
            else
            {
                ErrorMessage = "Credenziali non valide. Riprova.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Errore: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }
}
