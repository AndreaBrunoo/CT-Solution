@* Semplice dialog di conferma riutilizzabile *@
@if (IsVisible)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Title</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="Cancel"></button>
                </div>
                <div class="modal-body">
                    <p>@Message</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="Cancel">@CancelText</button>
                    <button class="btn btn-danger" @onclick="Confirm">@ConfirmText</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public string Title { get; set; } = "Conferma";

    [Parameter]
    public string Message { get; set; } = "Sei sicuro?";

    [Parameter]
    public string ConfirmText { get; set; } = "Conferma";

    [Parameter]
    public string CancelText { get; set; } = "Annulla";

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private async Task Confirm()
    {
        await OnConfirm.InvokeAsync(null);
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync(null);
    }
}